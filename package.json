{
  "name": "sticky-notes",
  "version": "1.0.0",
  "description": "Always-on-top sticky notes for Windows",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64"
  },
  "build": {
    "appId": "daxshonly.StickyNotesPro.Win32",
    "productName": "Sticky Notes",
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/logo.png"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Sticky Notes"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "home.html",
      "homeRenderer.js",
      "index.html",
      "style.css",
      "renderer.js",
      "assets/**"
    ]
  },git 
  "devDependencies": {
    "electron": "^42.3.2",
    "electron-builder": "^26.15.0"
  }
}