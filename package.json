{
  "name": "sticky-notes",
  "version": "1.0.0",
  "description": "Always-on-top sticky notes for Windows",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "dist:store": "electron-builder --win appx --x64",
    "dist:windows": "electron-builder --win --x64"
  },
  "build": {
    "appId": "daxshonly.StickyNotesPro.Win32",
    "productName": "Sticky Notes",
    "win": {
      "target": [
        "appx"
      ],
      "icon": "assets/logo.png"
    },
    "appx": {
      "applicationId": "daxshonly.StickyNotesPro.Win32",
      "identityName": "daxshonly.StickyNotesPro.Win32",
      "publisher": "CN=daxshonly, O=daxshonly, C=IN",
      "publisherDisplayName": "daxshonly",
      "displayName": "Sticky Notes",
      "backgroundColor": "#FFF6B8",
      "languages": [
        "en-US"
      ]
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "home.html",
      "homeRenderer.js",
      "index.html",
      "style.css",
      "renderer.js",
      "assets/**"
    ]
  },
  "devDependencies": {
    "electron": "^42.3.2",
    "electron-builder": "^26.8.1"
  }
}
